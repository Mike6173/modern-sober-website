<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    {%- if page_title == blank -%}
      Modern Søber
    {%- else -%}
      {{ page_title }} | Modern Søber
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  {{ content_for_header }}

  <!-- Google Fonts: Playfair Display + DM Sans + Cormorant Garamond -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

  {{ 'styles.css' | asset_url | stylesheet_tag }}
</head>
<body class="template-{{ request.page_type }}">

  {%- section 'header' -%}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  <script src="{{ 'theme.js' | asset_url }}" defer></script>

</body>
</html>
