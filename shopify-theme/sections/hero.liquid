<section class="hero-section" aria-label="Hero">

  <!-- Desktop background: modernsoberhero.png shifted right + left gradient -->
  <div class="hero-bg-desktop" aria-hidden="true">
    {%- if section.settings.bg_image_desktop != blank -%}
      <img
        src="{{ section.settings.bg_image_desktop | image_url: width: 1920 }}"
        alt=""
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <img
        src="{{ 'modernsoberhero.png' | asset_url }}"
        alt=""
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
    <div class="hero-bg-desktop-overlay"></div>
  </div>

  <!-- Mobile background: frosted yacht image -->
  <div class="hero-bg-mobile" aria-hidden="true">
    {%- if section.settings.bg_image_mobile != blank -%}
      <img
        src="{{ section.settings.bg_image_mobile | image_url: width: 900 }}"
        alt=""
        width="900"
        height="1200"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <img
        src="{{ 'hoodie-03-yacht-sitting.jpg' | asset_url }}"
        alt=""
        width="900"
        height="1200"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}
    <div class="hero-bg-mobile-overlay"></div>
  </div>

  <!-- Content -->
  <div class="hero-content">

    <p class="hero-label">MODERN SØBER</p>

    <h1 class="hero-h1 font-heading">
      {{- section.settings.heading | default: 'Clarity is a luxury.' -}}
    </h1>

    <p class="hero-sub">
      {{- section.settings.subheading | default: "You don't have to crash to change.\nYou just have to choose better." | newline_to_br -}}
    </p>

    <div class="hero-actions">
      {%- if section.settings.cta_primary_label != blank -%}
        <a href="{{ section.settings.cta_primary_url | default: '/collections/all' }}" class="btn-primary">
          {{- section.settings.cta_primary_label | default: 'SHOP NOW' -}}
        </a>
      {%- endif -%}

      {%- if section.settings.cta_secondary_label != blank -%}
        <a
          href="{{ section.settings.cta_secondary_url | default: settings.social_facebook }}"
          class="btn-outline"
          {% if section.settings.cta_secondary_url contains 'facebook' or section.settings.cta_secondary_url contains 'instagram' %}target="_blank" rel="noopener noreferrer"{% endif %}
        >
          <!-- Facebook icon -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
          {{- section.settings.cta_secondary_label | default: 'JOIN THE COMMUNITY' -}}
        </a>
      {%- endif -%}
    </div>

    {%- if section.settings.show_social_proof -%}
      <div class="hero-social-proof">
        <div class="social-proof-avatars" aria-hidden="true">
          <div class="avatar-circle">
            <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=80&h=80&q=80" alt="" width="32" height="32">
          </div>
          <div class="avatar-circle">
            <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=80&h=80&q=80" alt="" width="32" height="32">
          </div>
          <div class="avatar-circle">
            <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=80&h=80&q=80" alt="" width="32" height="32">
          </div>
          <div class="avatar-circle">
            <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=80&h=80&q=80" alt="" width="32" height="32">
          </div>
        </div>
        <p class="social-proof-text">
          Thousands are already<br>choosing clarity.
        </p>
      </div>
    {%- endif -%}

  </div><!-- /.hero-content -->

</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "bg_image_desktop", "label": "Background image (desktop)" },
    { "type": "image_picker", "id": "bg_image_mobile",  "label": "Background image (mobile)" },
    { "type": "text",     "id": "heading",              "label": "Headline",            "default": "Clarity is a luxury." },
    { "type": "textarea", "id": "subheading",           "label": "Subheading",          "default": "You don't have to crash to change.\nYou just have to choose better." },
    { "type": "text",     "id": "cta_primary_label",    "label": "Primary CTA label",   "default": "SHOP NOW" },
    { "type": "url",      "id": "cta_primary_url",      "label": "Primary CTA URL" },
    { "type": "text",     "id": "cta_secondary_label",  "label": "Secondary CTA label", "default": "JOIN THE COMMUNITY" },
    { "type": "url",      "id": "cta_secondary_url",    "label": "Secondary CTA URL" },
    { "type": "checkbox", "id": "show_social_proof",    "label": "Show social proof row","default": true },
    { "type": "text",     "id": "social_proof_text",    "label": "Social proof text",   "default": "Thousands are already choosing clarity." }
  ],
  "presets": [{ "name": "Hero", "category": "Hero" }]
}
{% endschema %}
