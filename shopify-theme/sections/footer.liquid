<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">

    <!-- ── Desktop 3-col grid / Mobile stacked ────────────────── -->
    <div class="footer-grid">

      <!-- Col 1: Wordmark -->
      <div class="footer-wordmark" aria-label="Modern Søber">
        MODERN<br>SØBER
      </div>

      <!-- Col 2: Nav links -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="/collections/all">SHOP</a>
        <a href="/pages/our-story">OUR STORY</a>
        <a href="/pages/community">COMMUNITY</a>
        <a href="/blogs/journal">JOURNAL</a>
        <a href="/pages/contact">CONTACT</a>
      </nav>

      <!-- Col 3: Social icons -->
      <div class="footer-social" aria-label="Social media links">

        {%- if settings.social_facebook != blank -%}
          <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_twitter != blank -%}
          <a href="{{ settings.social_twitter }}" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if settings.social_linkedin != blank -%}
          <a href="{{ settings.social_linkedin }}" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        {%- endif -%}

      </div>
    </div>

    <!-- ── Copyright bar ──────────────────────────────────────── -->
    <div class="footer-bottom">
      <p>© {{ 'now' | date: '%Y' }} Modern Søber. All rights reserved.</p>
    </div>

  </div><!-- /.footer-inner -->
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer navigation menu",
      "default": "footer"
    }
  ]
}
{% endschema %}
