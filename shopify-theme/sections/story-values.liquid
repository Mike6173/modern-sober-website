<section class="story-values" aria-label="Our values">
  <div class="story-values-grid">

    {%- assign value_defaults_title = 'QUIET CONFIDENCE,DISCIPLINE AS DESIGN,COMMUNITY OVER CROWD' | split: ',' -%}
    {%- assign value_defaults_body  = "Earned through consistency, not performance. We don't announce our discipline — we live it.,Every decision we make — in product, in community, in the words we choose — is intentional. Nothing here is accidental.,A smaller room with the right people moves faster than any crowd. We choose who we're in the room with." | split: ',' -%}

    {%- for i in (1..3) -%}
      {%- assign title_key = 'title_' | append: i -%}
      {%- assign body_key  = 'body_'  | append: i -%}
      {%- assign idx       = i | minus: 1 -%}
      <div>
        <h3 class="story-value-title font-heading">
          {{ section.settings[title_key] | default: value_defaults_title[idx] }}
        </h3>
        <p class="story-value-body">
          {{ section.settings[body_key] | default: value_defaults_body[idx] }}
        </p>
      </div>
    {%- endfor -%}

  </div>
</section>

{% schema %}
{
  "name": "Story Values",
  "settings": [
    { "type": "text",     "id": "title_1", "label": "Value 1 title", "default": "QUIET CONFIDENCE" },
    { "type": "textarea", "id": "body_1",  "label": "Value 1 body",  "default": "Earned through consistency, not performance. We don't announce our discipline — we live it." },
    { "type": "text",     "id": "title_2", "label": "Value 2 title", "default": "DISCIPLINE AS DESIGN" },
    { "type": "textarea", "id": "body_2",  "label": "Value 2 body",  "default": "Every decision we make — in product, in community, in the words we choose — is intentional. Nothing here is accidental." },
    { "type": "text",     "id": "title_3", "label": "Value 3 title", "default": "COMMUNITY OVER CROWD" },
    { "type": "textarea", "id": "body_3",  "label": "Value 3 body",  "default": "A smaller room with the right people moves faster than any crowd. We choose who we're in the room with." }
  ],
  "presets": [{ "name": "Story Values", "category": "Content" }]
}
{% endschema %}
