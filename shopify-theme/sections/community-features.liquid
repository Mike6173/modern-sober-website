<section class="community-features" aria-label="Community features">
  <div class="community-features-grid container">

    {%- assign feature_icons = 'chat,calendar,book,shield' | split: ',' -%}
    {%- assign feature_titles = section.settings.title_1 | default: 'Real conversations'
      | append: '||'
      | append: section.settings.title_2 | default: 'Member meetups'
      | append: '||'
      | append: section.settings.title_3 | default: 'Weekly field notes'
      | append: '||'
      | append: section.settings.title_4 | default: 'Private and protected'
      | split: '||' -%}
    {%- assign feature_subs = section.settings.sub_1 | default: 'No performance. No pretending.'
      | append: '||'
      | append: section.settings.sub_2 | default: 'In-person and virtual.'
      | append: '||'
      | append: section.settings.sub_3 | default: 'From the founder and members.'
      | append: '||'
      | append: section.settings.sub_4 | default: 'Closed group. Vetted members.'
      | split: '||' -%}

    {%- for i in (0..3) -%}
      <div class="feature-item">

        <div class="feature-icon-wrap" aria-hidden="true">
          {%- case feature_icons[i] -%}
            {%- when 'chat' -%}
              <!-- MessageCircle -->
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            {%- when 'calendar' -%}
              <!-- Calendar -->
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8"  y1="2" x2="8"  y2="6"/>
                <line x1="3"  y1="10" x2="21" y2="10"/>
              </svg>
            {%- when 'book' -%}
              <!-- BookOpen -->
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
              </svg>
            {%- when 'shield' -%}
              <!-- Shield -->
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
          {%- endcase -%}
        </div>

        <h3 class="feature-title font-heading">{{ feature_titles[i] }}</h3>
        <p class="feature-sub">{{ feature_subs[i] }}</p>

      </div>
    {%- endfor -%}

  </div>
</section>

{% schema %}
{
  "name": "Community Features",
  "settings": [
    { "type": "text", "id": "title_1", "label": "Feature 1 title", "default": "Real conversations" },
    { "type": "text", "id": "sub_1",   "label": "Feature 1 sub",   "default": "No performance. No pretending." },
    { "type": "text", "id": "title_2", "label": "Feature 2 title", "default": "Member meetups" },
    { "type": "text", "id": "sub_2",   "label": "Feature 2 sub",   "default": "In-person and virtual." },
    { "type": "text", "id": "title_3", "label": "Feature 3 title", "default": "Weekly field notes" },
    { "type": "text", "id": "sub_3",   "label": "Feature 3 sub",   "default": "From the founder and members." },
    { "type": "text", "id": "title_4", "label": "Feature 4 title", "default": "Private and protected" },
    { "type": "text", "id": "sub_4",   "label": "Feature 4 sub",   "default": "Closed group. Vetted members." }
  ],
  "presets": [{ "name": "Community Features", "category": "Content" }]
}
{% endschema %}
