<section class="page-hero" aria-label="Page header">
  <div class="page-hero-inner">

    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    <h1 class="page-hero-h1 font-heading">
      {{- section.settings.heading | default: page.title -}}
    </h1>

    {%- if section.settings.subtitle != blank -%}
      <p class="page-hero-subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Page Hero",
  "settings": [
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow label" },
    { "type": "text",     "id": "heading",  "label": "Heading" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle (optional)" }
  ],
  "presets": [{ "name": "Page Hero", "category": "Hero" }]
}
{% endschema %}
