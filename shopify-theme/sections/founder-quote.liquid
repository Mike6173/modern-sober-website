<section class="founder-quote-section" aria-label="Founder quote">
  <div class="founder-quote-inner">

    <div class="founder-quote-icon" aria-hidden="true">
      <svg width="28" height="22" viewBox="0 0 28 22" fill="#c8b89a" opacity="0.7">
        <path d="M0 22V13.2C0 5.6 4.4 1.4 13.2 0l1.4 2.8C10 3.8 7.8 6 7.2 9.6H12V22H0zm16 0V13.2C16 5.6 20.4 1.4 29.2 0L30.6 2.8C26 3.8 23.8 6 23.2 9.6H28V22H16z"/>
      </svg>
    </div>

    <p class="founder-quote-text font-heading">
      "{{- section.settings.quote | default: 'We are not a sobriety brand. We are a clarity brand. The two are not the same.' -}}"
    </p>

    <p class="founder-quote-attribution">
      — {{ section.settings.attribution | default: 'Founder' }}
    </p>

  </div>
</section>

{% schema %}
{
  "name": "Founder Quote",
  "settings": [
    { "type": "textarea", "id": "quote",       "label": "Quote text",  "default": "We are not a sobriety brand. We are a clarity brand. The two are not the same." },
    { "type": "text",     "id": "attribution", "label": "Attribution", "default": "Founder" }
  ],
  "presets": [{ "name": "Founder Quote", "category": "Content" }]
}
{% endschema %}
