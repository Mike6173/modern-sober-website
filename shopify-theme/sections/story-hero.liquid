<section class="story-hero" aria-label="Our Story header">

  <!-- Left: eyebrow + h1 -->
  <div class="story-hero-left">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="story-hero-h1 font-heading">
      {{- section.settings.heading | default: 'We started where excess ended.' -}}
    </h1>
  </div>

  <!-- Right: image -->
  <div class="story-hero-right">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1000 }}"
        alt="{{ section.settings.image.alt | escape | default: 'Founder portrait' }}"
        width="1000"
        height="1100"
        loading="eager"
      >
    {%- else -%}
      <div style="width:100%;height:100%;min-height:480px;background:var(--bg-cream-warm);"></div>
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Story Hero",
  "settings": [
    { "type": "text",         "id": "eyebrow", "label": "Eyebrow",   "default": "OUR STORY" },
    { "type": "text",         "id": "heading", "label": "Heading",   "default": "We started where excess ended." },
    { "type": "image_picker", "id": "image",   "label": "Hero image (right side)" }
  ],
  "presets": [{ "name": "Story Hero", "category": "Hero" }]
}
{% endschema %}
