<section class="home-community-section" aria-label="Community">

  <!-- Left: text + CTA -->
  <div class="home-community-left">

    <h2 class="home-community-title font-heading">
      {{- section.settings.heading | default: 'THIS IS BIGGER THAN PRODUCT.' | newline_to_br -}}
    </h2>

    <p class="home-community-body">
      {{- section.settings.body | default: "Modern Søber is a shift.\nPeople choosing clarity, discipline,\nand control — together.\nWe don't do this alone." | newline_to_br -}}
    </p>

    <a
      href="{{ section.settings.cta_url | default: settings.social_facebook }}"
      class="btn-primary"
      {% if section.settings.cta_url contains 'facebook' or section.settings.cta_url contains 'instagram' or settings.social_facebook == section.settings.cta_url %}target="_blank" rel="noopener noreferrer"{% endif %}
      style="max-width:260px;margin-bottom:20px;"
    >
      <!-- Facebook icon -->
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
      </svg>
      {{- section.settings.cta_label | default: 'JOIN THE COMMUNITY' -}}
    </a>

    <p class="home-community-note">
      {{- section.settings.cta_note | default: 'Private Facebook group. Real people. Real stories. No judgment.' -}}
    </p>

  </div>

  <!-- Right: 2×2 image grid -->
  <div class="home-community-img-grid" aria-hidden="true">

    {%- assign community_images = 'image_1,image_2,image_3,image_4' | split: ',' -%}
    {%- for img_id in community_images -%}
      <div class="img-cell">
        {%- assign img = section.settings[img_id] -%}
        {%- if img != blank -%}
          <img
            src="{{ img | image_url: width: 600 }}"
            alt=""
            width="600"
            height="600"
            loading="lazy"
          >
        {%- else -%}
          <div style="width:100%;height:100%;min-height:200px;background:var(--bg-cream-warm);display:flex;align-items:center;justify-content:center;">
            {%- if forloop.index == 2 -%}
              <p style="font-family:var(--font-body);font-size:13px;font-weight:500;letter-spacing:0.25em;color:var(--muted-3);text-align:center;line-height:1.6;">MODERN<br>SØBER</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}

  </div>

</section>

{% schema %}
{
  "name": "Home Community",
  "settings": [
    { "type": "text",         "id": "heading",   "label": "Heading",    "default": "THIS IS BIGGER\nTHAN PRODUCT." },
    { "type": "textarea",     "id": "body",      "label": "Body text",  "default": "Modern Søber is a shift.\nPeople choosing clarity, discipline,\nand control — together.\nWe don't do this alone." },
    { "type": "text",         "id": "cta_label", "label": "CTA label",  "default": "JOIN THE COMMUNITY" },
    { "type": "url",          "id": "cta_url",   "label": "CTA URL" },
    { "type": "text",         "id": "cta_note",  "label": "CTA note",   "default": "Private Facebook group. Real people. Real stories. No judgment." },
    { "type": "image_picker", "id": "image_1",   "label": "Grid image 1 (top-left)" },
    { "type": "image_picker", "id": "image_2",   "label": "Grid image 2 (top-right)" },
    { "type": "image_picker", "id": "image_3",   "label": "Grid image 3 (bottom-left)" },
    { "type": "image_picker", "id": "image_4",   "label": "Grid image 4 (bottom-right)" }
  ],
  "presets": [{ "name": "Home Community", "category": "Content" }]
}
{% endschema %}
